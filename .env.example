# Root env for docker compose.
# Copy to .env: cp .env.example .env
#
# Used by both base (docker-compose.yml) and prod overlay (docker-compose.prod.yml).

# ─── Local URLs (base stack) ─────────────────────────────────────────────────
# For OSS / self-host without a custom domain, leave these as-is.
# For the prod overlay, set both to https://${DOMAIN}.
NEXT_PUBLIC_API_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3000

# ─── Production overlay only ─────────────────────────────────────────────────
# Public domain — used by Nginx server_name and CORS.
# Only required when running with docker-compose.prod.yml.
DOMAIN=yourdomain.com

# ─── Database / Redis passwords ──────────────────────────────────────────────
# Generate: openssl rand -base64 32
DB_PASS=changeme
REDIS_PASS=changeme

# ─── JWT / Auth ──────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=changeme
JWT_REFRESH_SECRET=changeme
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Encryption key for stored API keys — 64 hex chars
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=changeme

# ─── AI provider ─────────────────────────────────────────────────────────────
# "anthropic" (default) | "ollama"
AI_PROVIDER=anthropic

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Ollama (only if AI_PROVIDER=ollama)
# From inside Docker on macOS/Windows, use host.docker.internal:
# OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:7b
