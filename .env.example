# Database — get this from Supabase -> Settings -> Database -> Connection string
# Use the "Transaction" connection pooler URL for Prisma
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection for Prisma migrations (non-pooled)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

ENCRYPTION_KEY="generate-a-random-64-char-string-here"
# JWT
JWT_SECRET="generate-a-random-64-char-string-here"
JWT_REFRESH_SECRET="generate-a-different-random-64-char-string-here"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# AI provider selection: "anthropic" (default) | "ollama"
AI_PROVIDER="ollama"

# Anthropic (used when AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-sonnet-4-6"

# Ollama (used when AI_PROVIDER=ollama)
# Run Ollama locally: https://ollama.com — then: ollama pull qwen2.5:7b
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="qwen2.5:7b"

# ChromaDB — vector store for RAG context (run: docker compose up -d)
CHROMA_URL="http://localhost:8001"

# Redis — job queue for async AI operations (run: docker compose up -d)
REDIS_URL="redis://localhost:6379"

# App
PORT=4000
CORS_ORIGIN="http://localhost:3000"
NODE_ENV="development"
