# ─── Self-hosting (docker-compose production) ────────────────────────────────
# Your public domain (used by Nginx + CORS + NEXT_PUBLIC_API_URL bake-in)
DOMAIN=yourdomain.com

# Database password — used by postgres container and DATABASE_URL
# Generate: openssl rand -base64 32
DB_PASS=changeme

# Redis password — used by redis container and REDIS_URL
# Generate: openssl rand -base64 32
REDIS_PASS=changeme

# ─── JWT / Auth ───────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=changeme
JWT_REFRESH_SECRET=changeme
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Encryption key for stored API keys — 64 hex chars
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=changeme

# ─── AI provider ─────────────────────────────────────────────────────────────
# "anthropic" (default) | "ollama"
AI_PROVIDER=anthropic

# Anthropic (used when AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Ollama (used when AI_PROVIDER=ollama)
# Run Ollama locally: https://ollama.com — then: ollama pull qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ─── Infrastructure (docker-compose sets these automatically — do not change) ─
# DATABASE_URL and REDIS_URL are injected by docker-compose using DB_PASS / REDIS_PASS above.
# CHROMA_URL=http://chromadb:8000
# CORS_ORIGIN=https://${DOMAIN}

# ─── Supabase (cloud-hosted alternative to local postgres) ────────────────────
# Uncomment and fill these if using Supabase instead of the postgres container.
# DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"
