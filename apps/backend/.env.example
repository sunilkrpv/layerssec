# ─── Self-hosting (docker-compose production) ────────────────────────────────
# Your public domain (used by Nginx + CORS + NEXT_PUBLIC_API_URL bake-in)
DOMAIN=yourdomain.com

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/layers?schema=public"

# Database password — used by postgres container and DATABASE_URL
# Generate: openssl rand -base64 32
DB_PASS=changeme

# Redis password — used by redis container and REDIS_URL
# Generate: openssl rand -base64 32
REDIS_PASS=changeme

# ─── JWT / Auth ───────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=changeme
JWT_REFRESH_SECRET=changeme
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Encryption key for stored API keys — 64 hex chars
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=changeme

# App
PORT=4000
CORS_ORIGIN="http://localhost:3000"
NODE_ENV="development"

# ChromaDB
CHROMA_URL="http://localhost:8001"

# Redis — job queue for async AI operations (run: docker compose up -d)
REDIS_URL="redis://localhost:6379"
