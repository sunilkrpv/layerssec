# JWT — generate secure random strings (e.g. openssl rand -hex 32)
JWT_SECRET=change-me-at-least-32-chars
JWT_REFRESH_SECRET=change-me-different-at-least-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# AI provider: anthropic | ollama
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Ollama (only needed when AI_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=qwen2.5:7b

# Supabase Storage (optional — for thumbnails)
# SUPABASE_URL=https://[project-ref].supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Encryption key for stored API keys — 64 hex chars (32 bytes)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=change-me-must-be-64-hex-characters-000000000000000000000000000000
